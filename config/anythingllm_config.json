{
  "workspaces": [
    {
      "id": "coach",
      "name": "高管教练",
      "description": "你的个人高管AI助手，根据你��职位和阶段提供建议",
      "type": "chat",
      "llmProvider": "deepseek",
      "systemPrompt": "你是一位资深的IT行业投资人和企业战略顾问。根据用户的职位、职业阶段和具体问题，从知识库中检索相关资料，并以高管的视角提供专业建议。",
      "dataSource": "all",
      "features": [
        "职业阶段识别",
        "个性化推荐",
        "知识库检索",
        "实时建议"
      ]
    },
    {
      "id": "classifier",
      "name": "文档分类器",
      "description": "自动分析和分类你上传的所有文档，生成元数据标签",
      "type": "utility",
      "llmProvider": "deepseek",
      "systemPrompt": "你是一个文档分类专家。分析提交的文档，识别其主要角色、子领域、职业阶段、关键词等信息。用JSON格式返回分类结果。",
      "classificationSchema": {
        "mainRole": ["CIO", "CEO", "CFO", "CTO", "CISO", "CDAO", "CSO", "CVC", "投资VP", "基金经理", "企业战略投资"],
        "subDomains": "string",
        "careerStage": ["初级", "中级", "资深"],
        "keywords": "array",
        "useCase": "string"
      }
    },
    {
      "id": "news",
      "name": "行业新闻",
      "description": "每天自动爬取和分类最新的AI行业新闻",
      "type": "knowledge",
      "llmProvider": "deepseek",
      "systemPrompt": "你是一个行业新闻分析员。总结最新的AI和科技行业新闻，突出对高管决策的影响。",
      "dataSources": [
        "Hacker News",
        "Deloitte Insights",
        "Twitter/X",
        "TechCrunch",
        "VentureBeat"
      ],
      "updateFrequency": "daily"
    }
  ],
  "vectorStore": {
    "type": "lancedb",
    "location": "local",
    "embeddingModel": "text-embedding-3-small",
    "chunkSize": 1000,
    "chunkOverlap": 200
  },
  "documentSettings": {
    "supportedFormats": [
      "pdf",
      "docx",
      "pptx",
      "txt",
      "md",
      "jpg",
      "png"
    ],
    "maxFileSize": "100MB",
    "autoOCR": true
  }
}
